<Window x:Class="DotRace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pötty Verseny - Időzítő" Height="573" Width="950">
    <StackPanel Margin="10">
        <Button Name="StartButton" Content="START" Click="StartButton_Click" 
                Width="120" Height="50" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Name="CountdownText" FontSize="48" FontWeight="Bold" 
                   HorizontalAlignment="Center" Foreground="Blue" Margin="0,0,0,20"/>

        <TextBlock Name="StatusText" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Name="TimesText" FontSize="16" HorizontalAlignment="Center" 
                   TextWrapping="Wrap" Margin="0,0,0,20"/>

        <Canvas Name="TrackCanvas" Width="900" Height="180" Background="LightGray" Margin="10">
            <Rectangle Canvas.Left="870" Canvas.Top="15" Width="4" Height="150" 
                       Fill="Black" Stroke="Black" StrokeThickness="3"/>

            <Ellipse Name="RedDot" Width="28" Height="28" Fill="Red" Stroke="DarkRed" StrokeThickness="2"
                     Canvas.Left="10" Canvas.Top="25"/>
            <Ellipse Name="WhiteDot" Width="28" Height="28" Fill="White" Stroke="Black" StrokeThickness="3"
                     Canvas.Left="10" Canvas.Top="75"/>
            <Ellipse Name="GreenDot" Width="28" Height="28" Fill="LimeGreen" Stroke="DarkGreen" StrokeThickness="2"
                     Canvas.Left="10" Canvas.Top="125"/>
        </Canvas>
    </StackPanel>
</Window>
